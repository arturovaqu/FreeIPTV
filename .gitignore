# ─────────────────────────────────────────────────────────────────────────────
# Flutter / Dart
# ─────────────────────────────────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
dart_tool/

# ─────────────────────────────────────────────────────────────────────────────
# Build output — ignore everything EXCEPT the release APK
# ─────────────────────────────────────────────────────────────────────────────
build/

# Re-include the release APK so it can be distributed via the repo
!build/
!build/app/
!build/app/outputs/
!build/app/outputs/flutter-apk/
!build/app/outputs/flutter-apk/app-release.apk
!build/app/outputs/flutter-apk/app-release.apk.sha1

# ─────────────────────────────────────────────────────────────────────────────
# Android
# ─────────────────────────────────────────────────────────────────────────────
# Local SDK/NDK paths — machine-specific, never commit
android/local.properties
# Gradle caches and build internals
android/.gradle/
android/.kotlin/
# Generated files
android/app/src/main/GeneratedPluginRegistrant.java

